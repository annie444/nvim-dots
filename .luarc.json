{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "format.enable": false,
  "workspace.library": [
    "$VIMRUNTIME",
    "$XDG_DATA_HOME/nvim/lazy",
    "$HOME/.local/share/nvim/lazy",
    "${3rd}/luv/library",
    "/opt/homebrew/opt/nvim/share/nvim/runtime/lua",
    "$HOME/.dotfiles/nvim-dots/lua",
    "$HOME/.local/share/nvim/lazy/lazy.nvim/lua",
    "$HOME/.local/share/nvim/lazy/direnv.nvim/lua",
    "$HOME/.local/share/nvim/lazy/AstroNvim/lua",
    "$HOME/.local/share/nvim/lazy/nvim-autopairs/lua",
    "$HOME/.local/share/nvim/lazy/astroui/lua",
    "$HOME/.local/share/nvim/lazy/astrocore/lua",
    "$HOME/.local/share/nvim/lazy/none-ls.nvim/lua",
    "$HOME/.local/share/nvim/lazy/mini.icons/lua",
    "$HOME/.local/share/nvim/lazy/snacks.nvim/lua",
    "$HOME/.config/nvim/lua"
  ]
}
